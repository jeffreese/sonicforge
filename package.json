{
  "name": "sonicforge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "biome check src/ tools/",
    "format": "biome format --write src/ tools/",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky",
    "build:index": "tsc -p tools/composition-index/tsconfig.json",
    "rebuild:index": "pnpm build:index && node tools/composition-index/dist/build.js"
  },
  "dependencies": {
    "lit": "^3.2.0",
    "tone": "^15.0.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^25.6.0",
    "autoprefixer": "^10.4.20",
    "husky": "^9.1.0",
    "jsdom": "^29.0.0",
    "lint-staged": "^15.2.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "lint-staged": {
    "{src,tools}/**/*.{ts,js}": [
      "biome check --no-errors-on-unmatched",
      "vitest related --run"
    ]
  }
}

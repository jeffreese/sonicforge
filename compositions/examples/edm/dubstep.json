{
  "version": "1.0",
  "metadata": {
    "title": "Dubstep Example",
    "bpm": 140,
    "timeSignature": [4, 4],
    "key": "E minor",
    "description": "Minimal dubstep at 140 BPM (half-time feel, kick on 1, snare on 3). Wobble bass via LFO at 8n rate → bass.filter.frequency between 150 Hz and 2.5 kHz. Mono wobble bass (required for LFO modulation), trap-style hat rolls, minimal melody."
  },
  "instruments": [
    {
      "id": "drums",
      "name": "Dubstep Kit",
      "category": "drums",
      "source": "oneshot",
      "oneshots": {
        "kick": "samples/oneshots/kicks/265328__xkpl_klawz__big-room-kick-punchy.wav",
        "snare": "samples/oneshots/snares/673516__theendofacycle__flat-fat-snare-drum-hit.wav",
        "hat": "samples/oneshots/hats/811628__m0nsterhd__closed-hi-hat.wav",
        "clap": "samples/oneshots/claps/199266__stumber__diamond_clap_05.wav"
      },
      "defaultVolume": 92,
      "effects": [
        { "type": "compressor", "params": { "threshold": -12, "ratio": 4 } }
      ]
    },
    {
      "id": "bass",
      "name": "Wobble Bass",
      "category": "bass",
      "source": "synth",
      "synth": {
        "type": "mono",
        "oscillator": { "type": "sawtooth" },
        "envelope": { "attack": 0.005, "decay": 0.3, "sustain": 0.95, "release": 0.15 },
        "filter": { "type": "lowpass", "frequency": 400, "Q": 8, "rolloff": -24 },
        "filterEnvelope": {
          "attack": 0.005,
          "decay": 0.1,
          "sustain": 1,
          "release": 0.1,
          "baseFrequency": 100,
          "octaves": 3
        }
      },
      "defaultVolume": 85
    }
  ],
  "masterEffects": [
    { "type": "eq3", "params": { "low": 2, "mid": 0, "high": 0 } },
    { "type": "limiter", "params": { "threshold": -1 } }
  ],
  "lfos": [
    { "id": "wobble", "frequency": "8n", "type": "sine", "min": 150, "max": 2500 }
  ],
  "modulation": [
    { "source": "wobble", "target": "bass.filter.frequency" }
  ],

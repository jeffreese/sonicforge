{
  "version": "1.0",
  "metadata": {
    "title": "Wobblepump",
    "bpm": 140,
    "timeSignature": [
      4,
      4
    ],
    "key": "E minor",
    "description": "Sub-epic #4 verification — exercises SidechainRouter and ModulationEngine together. A dubstep-ish groove in E minor with: (1) a mono wobble bass whose filter cutoff is modulated by an LFO at 8n rate, sweeping 120 Hz to 2 kHz (LFO → synth-internal filter.frequency path from sub-epic #4 commit 1), (2) a sustained warm pad that gets ducked by the kick drum on every beat (kick → pad sidechain with amount 0.85 and 100ms release for clear pumping), and (3) a supersaw stab layer that also gets ducked (secondary sidechain target sharing the same kick source). Simple 4-bar pattern that loops across 8 bars.",
    "tags": [
      "dubstep",
      "demo",
      "wobble-bass",
      "sidechained",
      "minimal"
    ]
  },
  "instruments": [
    {
      "id": "kick",
      "name": "Kick",
      "category": "drums",
      "source": "drums",
      "defaultVolume": 90
    },
    {
      "id": "bass",
      "name": "Wobble Bass",
      "category": "bass",
      "source": "synth",
      "synth": {
        "type": "mono",
        "oscillator": {
          "type": "sawtooth"
        },
        "envelope": {
          "attack": 0.005,
          "decay": 0.3,
          "sustain": 0.9,
          "release": 0.2
        },
        "filter": {
          "type": "lowpass",
          "frequency": 400,
          "Q": 8,
          "rolloff": -24
        },
        "filterEnvelope": {
          "attack": 0.005,
          "decay": 0.15,
          "sustain": 0.8,
          "release": 0.2,
          "baseFrequency": 100,
          "octaves": 3
        }
      },
      "defaultVolume": 82,
      "effects": [
        {
          "type": "compressor",
          "params": {
            "threshold": -16,
            "ratio": 4
          }
        }
      ]
    },
    {
      "id": "pad",
      "name": "Warm Pad",
      "category": "pad",
      "source": "synth",
      "synth": "warm_pad",
      "defaultVolume": 65,
      "effects": [
        {
          "type": "reverb",
          "params": {
            "decay": 5,
            "wet": 0.4
          }
        }
      ]
    },
    {
      "id": "stab",
      "name": "Supersaw Stab",
      "category": "melodic",
      "source": "synth",
      "synth": "supersaw_lead",
      "defaultVolume": 60,
      "effects": [
        {
          "type": "reverb",
          "params": {
            "decay": 2,
            "wet": 0.25
          }
        }
      ]
    }
  ],
  "lfos": [
    {
      "id": "wobble",
      "frequency": "8n",
      "type": "sine",
      "min": 120,
      "max": 2000
    }
  ],
  "modulation": [
    {
      "source": "wobble",
      "target": "bass.filter.frequency"
    }
  ],
  "sidechain": [
    {
      "source": "kick",
      "target": "pad",
      "amount": 0.85,
      "release": 0.1
    },
    {
      "source": "kick",
      "target": "stab",
      "amount": 0.6,
      "release": 0.08
    }
  ],

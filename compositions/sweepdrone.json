{
  "version": "1.0",
  "metadata": {
    "title": "Sweepdrone",
    "bpm": 120,
    "timeSignature": [4, 4],
    "key": "A minor",
    "description": "Sub-epic #3 verification — exercises the AutomationEngine. A sustained reese bass + supersaw lead with: (1) a linear volume ramp on the lead that swells over 8 bars, (2) a linear automation sweep of a named 'drop' reverb's wet level from dry to soaked and back, (3) a linear ramp on master limiter threshold for a final crush, and (4) a step-curve pan flip. Tests track params, effect-by-id targeting, effect-by-type targeting, master bus params, and linear/step curves. (Exponential curves only work for strictly-positive params per Web Audio API; dB-ranged params like limiter threshold must use linear.)"
  },
  "instruments": [
    {
      "id": "bass",
      "name": "Reese Bass",
      "category": "bass",
      "source": "synth",
      "synth": "reese_bass",
      "defaultVolume": 80,
      "effects": [
        { "type": "compressor", "params": { "threshold": -18, "ratio": 4 } }
      ]
    },
    {
      "id": "lead",
      "name": "Supersaw Lead",
      "category": "melodic",
      "source": "synth",
      "synth": "supersaw_lead",
      "defaultVolume": 20,
      "effects": [
        {
          "type": "reverb",
          "id": "drop",
          "params": { "decay": 4, "wet": 0.0 }
        },
        {
          "type": "reverb",
          "id": "tail",
          "params": { "decay": 2, "wet": 0.15 }
        }
      ]
    },
    {
      "id": "pad",
      "name": "Warm Pad",
      "category": "pad",
      "source": "synth",
      "synth": "warm_pad",
      "defaultVolume": 50,
      "effects": [
        { "type": "reverb", "params": { "decay": 5, "wet": 0.3 } }
      ]
    }
  ],
  "masterEffects": [
    { "type": "eq3", "params": { "low": 1, "mid": 0, "high": -1 } },
    { "type": "limiter", "params": { "threshold": -3 } }
  ],
